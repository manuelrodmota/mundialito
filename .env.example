# ─────────────────────────────────────────────────────────────────────────────
# Local Supabase dev config. Copy this file to .env.local (gitignored):
#
#     cp .env.example .env.local
#
# IMPORTANT: the keys below are Supabase's PUBLIC local-only demo keys
# (JWT issuer "supabase-demo"). They are NOT secrets:
#   • every `supabase start`, on every machine, generates these exact values;
#   • they are published in Supabase's own docs and source;
#   • they only work against a LOCAL stack — they grant nothing on any hosted
#     or production project.
# They are safe to commit. NEVER paste a real hosted/production key in this file
# (real hosted keys belong in your deployment platform's env vars, e.g. Vercel).
# ─────────────────────────────────────────────────────────────────────────────

# Client (browser) — anon key only. Vite exposes only VITE_* vars to the bundle.
VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Seed script only (server-side). `pnpm seed` reads these from the environment
# (see the seed command in README.md). Never expose as a VITE_* var. This is the
# standard LOCAL default service-role key — run `supabase status` if yours differs.
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Hosted Supabase (only when deploying to the cloud — do NOT commit real values).
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<hosted-anon-key>
